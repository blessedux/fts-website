# =============================================================================
# FTS — environment template
# Copy to `.env.local` for local development. Never commit real secrets.
# =============================================================================

# --- Public site URL (emails, payment back_urls, webhook notification_url) ---
BOOKING_PUBLIC_BASE_URL=http://localhost:3000

# --- Mercado Pago (Commerce & payments v1) ---
# Provider: Mercado Pago only for AR + CL. SumUp is deferred (not required).
#
# Create one application (or test credentials) per country in:
#   https://www.mercadopago.com.ar/developers/panel/app  (AR / MLA)
#   https://www.mercadopago.cl/developers/panel/app      (CL / MLC)
#
# Use TEST access tokens for sandbox smoke checks.
# AR online checkout stays OFF until MP_ACCESS_TOKEN_AR is set.
# Without it, AR book buyers get an in-app message + admin email (no redirect).
MP_ACCESS_TOKEN_AR=
MP_ACCESS_TOKEN_CL=

# Webhook secrets from Your integrations → Webhooks → Configure notification.
# Point each app at:
#   {BOOKING_PUBLIC_BASE_URL}/api/payments/webhook?country=AR
#   {BOOKING_PUBLIC_BASE_URL}/api/payments/webhook?country=CL
MP_WEBHOOK_SECRET_AR=
MP_WEBHOOK_SECRET_CL=

# Optional fallbacks (prefer per-country vars above)
# MP_ACCESS_TOKEN=
# MP_WEBHOOK_SECRET=
# MERCADO_PAGO_ACCESS_TOKEN=

# Default country when callers omit `country` (AR | CL)
MP_DEFAULT_COUNTRY=CL

# Catalog prices live in lib/commerce/catalog.ts:
#   Book CL: 24990 CLP · AR: 25000 ARS (ARS checkout deferred)
#   Session CL: 45000 CLP · AR: 45000 ARS (pay-after only; not in public cart)
#
# Payment e2e (local/CI):
#   npm run dev -- --port 3002
#   npm run test:payments
# Optional: PAYMENTS_SMOKE_EMAIL for session email delivery during e2e



# --- Booking (existing) ---
# DATABASE_URL=
# BOOKING_ORGANIZER_EMAIL=
# BOOKING_ICS_DOWNLOAD_SECRET=
# RESEND_API_KEY=
# RESEND_FROM_EMAIL=
